# Local server configuration for TexLocal
# Copy this file to local-server/.env and adjust values as needed.

# HTTP port for the local API server
PORT=3001

# Storage directory for user projects.
# Absolute path recommended.
# Relative paths are resolved from the local-server/ folder.
#
# Windows example:
# TEXLOCAL_ROOT=C:\Users\your-name\Documents\TexLocalProjects
#
# macOS/Linux example:
# TEXLOCAL_ROOT=~/Documents/TexLocalProjects
TEXLOCAL_ROOT=../TexLocalProjects
